pipeline/out/
node_modules/
dist/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
app/public/data/
app/node_modules/
app/dist/

# TypeScript build info
*.tsbuildinfo
app/public/models/
app/public/data/embeddings.*
app/public/ort/

